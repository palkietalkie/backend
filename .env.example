# Canonical list of SECRETS the running backend reads.
# Pre-commit checks .env / .env.production / Fly secrets against this file.
#
# Non-secret runtime config (URLs, hostnames, public IDs, model names) lives in fly.toml [env] / fly.dev.toml [env].
# Sensible local-dev defaults are encoded in app/config.py Settings, so .env only needs to supply credentials and dev-specific overrides.

# ============================================================================
# SECRETS
# ============================================================================

# Neon Postgres connection URL (contains the password).
NEON_DATABASE_URL=postgresql://user:pass@ep-foo.us-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Pinecone API key.
# Dashboard: https://app.pinecone.io
PINECONE_API_KEY=pcsk_xxx

# Stripe secret + webhook signing secret.
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Apple App-Specific Shared Secret — legacy iTunes Connect /verifyReceipt validation. Distinct from the StoreKit + ASC API keys below.
# Dashboard: https://appstoreconnect.apple.com → My Apps → App-Specific Shared Secret
APPLE_VERIFY_RECEIPT_SHARED_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Apple App Store Server API key (talks to api.storekit.itunes.apple.com — request test notifications, look up transactions, send consumption info). Issuer ID + Key ID from App Store Connect → Users and Access → Integrations → In-App Purchase / App Store Server API subtab.
APPLE_STOREKIT_ISSUER_ID=00000000-0000-0000-0000-000000000000
APPLE_STOREKIT_KEY_ID=XXXXXXXXXX
# .p8 private-key contents (newlines preserved). Local dev: NOT typed here — file lives at backend/secrets/apple_storekit_api.p8 and conftest.py loads it into os.environ at test start. Fly deploys + CI set the value directly.
APPLE_STOREKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Apple App Store Connect API key (talks to api.appstoreconnect.apple.com — manage app metadata, create IAPs, TestFlight). Same team issuer as the StoreKit key. Key generated under App Store Connect API subtab (not "In-App Purchase").
APPLE_ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
APPLE_ASC_KEY_ID=XXXXXXXXXX
APPLE_ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google AI Studio API key (used for both Gemini and Gemma endpoints).
# Dashboard: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxx

# OpenAI key — mints ephemeral tokens for gpt-realtime on the OpenAI Realtime inference path.
# Dashboard: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# News API key for the "Today" screen.
# Dashboard: https://newsapi.org/account
NEWS_API_KEY=xxxxxxxx

# Neo4j AuraDB password (URI + user are in fly.toml [env]).
# Dashboard: https://console.neo4j.io
NEO4J_PASSWORD=changeme

# Hugging Face token (used by Modal to download gated PersonaPlex weights).
# Dashboard: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxx

# Google OAuth client secret (client ID is in fly.toml [env]).
# Dashboard: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# HMAC signing for the per-conversation PersonaPlex WS ticket.
# Same value MUST be set on the Modal env (`modal secret create ws_ticket WS_TICKET_SECRET=...`).
WS_TICKET_SECRET=changeme

# Bot User OAuth Token for the PT Slack workspace (xoxb-…). Powers outbound chat.postMessage from the backend (future GTM/hiring/fundraising notifications). Same token also lives in scripts/slack.sh and the website (waitlist signup posts).
# Channel IDs are PUBLIC identifiers and live in fly.toml [env] / fly.dev.toml [env] (e.g. SLACK_CHANNEL_GTM) — NOT here.
# Dashboard: https://api.slack.com/apps → Palkie Talkie Bot → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-xxx
