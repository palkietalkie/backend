# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=https://palkietalkie.com,http://localhost:3000

# --- Neon (Postgres) ---
NEON_DATABASE_URL=postgresql://user:pass@ep-foo.us-west-2.aws.neon.tech/palkietalkie

# --- Neo4j AuraDB ---
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Pinecone ---
PINECONE_API_KEY=pcsk_xxx
PINECONE_INDEX=palkietalkie

# --- Clerk ---
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Apple ---
APPLE_BUNDLE_ID=ai.palkietalkie.app
APPLE_ASN_SHARED_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLMs ---
# Google AI Studio API key (same key works for both Gemini and Gemma endpoints).
GEMINI_API_KEY=xxxxxxxx
# OpenAI key; used by the OpenAI Realtime path of /conversation/start to mint ephemeral session tokens for gpt-realtime. Switch providers via INFERENCE_PROVIDER (default "openai"; set "personaplex" to route to NVIDIA PersonaPlex on Modal).
OPENAI_API_KEY=sk-xxx

# --- News ---
NEWS_API_KEY=xxxxxxxx

# --- APNs ---
APNS_KEY_ID=ABCDEF1234
APNS_TEAM_ID=ABCDEF1234
APNS_AUTH_KEY_PATH=/run/secrets/apns_auth_key.p8
APNS_USE_SANDBOX=true

# --- PersonaPlex (Lambda Labs) ---
PERSONAPLEX_HOST=10.0.0.1
PERSONAPLEX_PORT=8080
# "wss" in prod, "ws" for local dev / SSH-tunneled testing.
PERSONAPLEX_SCHEME=wss
# HMAC secret for signing the per-conversation WebSocket ticket. Must match the value on the PersonaPlex Modal app. Required when INFERENCE_PROVIDER=personaplex.
WS_TICKET_SECRET=changeme

# --- Google OAuth (Calendar) ---
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx
GOOGLE_OAUTH_REDIRECT_URI=https://api.palkietalkie.com/integrations/google-calendar/callback
