#!/usr/bin/env bash
# Pre-commit hook for the backend repo.
# Wired via `git config core.hooksPath scripts/git`.
# Runs the same checks CI runs (ruff format, ruff check, pyright) so a clean commit lands a green PR.
# Pytest is intentionally out of scope: too slow + needs Docker (testcontainers).

set -e

cd "$(git rev-parse --show-toplevel)"

# Refuse `git commit <pathspec>`. When git assembles a partial commit from a working-tree pathspec, it routes the hook through a temp index (e.g. `.git/next-index-12345`) instead of `.git/index`. That bypasses whatever was staged AND quietly picks up unstaged hunks in the named files — a footgun in multi-session workflows.
if [ -n "$GIT_INDEX_FILE" ] && [ "$(basename "$GIT_INDEX_FILE")" != "index" ]; then
    echo "pre-commit: REFUSED — 'git commit <pathspec>' detected (GIT_INDEX_FILE=$GIT_INDEX_FILE)." >&2
    echo "  This snapshots the working tree of those paths and bypasses the staging boundary." >&2
    echo "  Stage explicitly then commit:  git add <files> && git commit -m '...'" >&2
    exit 1
fi

# Prefer the project venv binaries directly (git commit runs hooks with a minimal env that doesn't include any activated venv on PATH).
VENV_BIN=".venv/bin"
RUFF="$VENV_BIN/ruff"
PYRIGHT="$VENV_BIN/pyright"

if [ ! -x "$RUFF" ]; then
    echo "pre-commit: $RUFF missing — run 'uv pip install -e \".[dev]\"' inside .venv" >&2
    exit 1
fi
if [ ! -x "$PYRIGHT" ]; then
    echo "pre-commit: $PYRIGHT missing — run 'uv pip install -e \".[dev]\"' inside .venv" >&2
    exit 1
fi

echo "pre-commit: regenerate app/services/neon/rows.py from live Neon schema"
ROWS_PY="app/services/neon/rows.py"
ROWS_PY_BEFORE=$(cat "$ROWS_PY" 2>/dev/null || true)
uv run scripts/neon/generate_neon_types.py
# Format the generated file so the drift check compares apples to apples (committed file is already ruff-formatted).
"$RUFF" format --quiet "$ROWS_PY"
ROWS_PY_AFTER=$(cat "$ROWS_PY")
if [ "$ROWS_PY_BEFORE" != "$ROWS_PY_AFTER" ]; then
    echo "pre-commit: $ROWS_PY drifted from live Neon schema — re-stage it and re-commit" >&2
    exit 1
fi

# Reformat in place, then auto-restage ruff's changes — but ONLY for files that were already staged and were otherwise clean. A file with pre-existing unstaged edits is left alone (re-adding it would silently fold unreviewed work into the commit), and unstaged files are never introduced. This reduces the manual re-stage burden a check-and-fail hook imposes without the auto-staging footgun.
echo "pre-commit: ruff format (auto-restage formatter changes to cleanly-staged files)"
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
DIRTY_BEFORE=$(git diff --name-only)
"$RUFF" format app/ inference/ scripts/ migrations/ conftest.py
git diff --name-only | while read -r f; do
    [ -z "$f" ] && continue
    echo "$STAGED" | grep -qx "$f" || continue        # only files that were staged
    echo "$DIRTY_BEFORE" | grep -qx "$f" && continue  # skip files that already had unstaged edits
    git add "$f" && echo "pre-commit: re-staged formatter changes in $f"
done

echo "pre-commit: ruff check"
"$RUFF" check app/ inference/ scripts/ migrations/ conftest.py

echo "pre-commit: pyright"
"$PYRIGHT"

echo "pre-commit: check env drift (.env/.env.production/fly.toml/fly.dev.toml vs .env.example)"
uv run scripts/check_env_drift.py

# End-to-end: deploy backend + Modal voice to dev so the freshly-committed code goes live on the dev infra the phone hits.
# Skip the iOS install since this is the backend repo; the iOS hook handles its own install.
BOOT_SH="$(git rev-parse --show-toplevel)/../scripts/boot.sh"
if [ -x "$BOOT_SH" ]; then
    echo "pre-commit: boot.sh --no-ios (deploy backend + Modal dev)"
    "$BOOT_SH" --no-ios
fi
