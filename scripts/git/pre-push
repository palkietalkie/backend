#!/usr/bin/env bash
# Pre-push: run the branch-level check that CI enforces, so a red PR never leaves the machine.
#
# The paired-test guard compares the whole branch against origin/main — a branch-level invariant, NOT a per-commit one. It lives here (pre-push), not in pre-commit: in pre-commit it would wrongly reject committing a source file in one commit and its test in the next. Pre-push runs once on the exact state about to become the PR, which mirrors CI.
set -e

REPO="$(git rev-parse --show-toplevel)"
echo "[pre-push] paired-test guard (same check CI runs)..."
bash "$REPO/scripts/ci/check_test_pair.sh" origin/main

# Branch-level coverage gate (CI parity). The testcontainers Postgres warmup makes it too slow for per-commit.
echo "[pre-push] pytest + 90 percent coverage gate..."
VENV_BIN="$REPO/.venv/bin"
PYTEST_ADDOPTS="" "$VENV_BIN/pytest" \
    -m "not sandbox" \
    --cov=app \
    --cov-branch \
    --cov-report=term-missing \
    --cov-fail-under=90
